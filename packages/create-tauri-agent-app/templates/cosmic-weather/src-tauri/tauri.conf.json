{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cosmic Weather",
  "version": "0.1.0",
  "identifier": "io.dspo.cosmicweather",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cosmic Weather",
        "width": 1240,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
